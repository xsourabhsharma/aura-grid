# Aura-Grid Environment Configuration
# Copy this file to .env and configure your desired AI model

# Option 1: Local Ollama (Default)
AI_API_KEY=dummy_key_for_local
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=qwen3.5:2b

# Option 2: OpenAI (GPT-4o, etc.)
# AI_API_KEY=sk-your-openai-api-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# Option 3: OpenRouter (Access to Claude 3.5 Sonnet, Gemini 1.5 Pro, Llama 3.1, etc.)
# AI_API_KEY=sk-or-v1-your-openrouter-key
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=anthropic/claude-3.5-sonnet

# Option 4: DeepSeek
# AI_API_KEY=sk-your-deepseek-key
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-coder

# Option 5: Groq (Ultra-fast cloud)
# AI_API_KEY=gsk_your-groq-api-key
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama3-8b-8192